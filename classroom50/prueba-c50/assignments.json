          "exit-code": 0,
          "points": 4
        },
        {
          "name": "Termina correctamente",
          "type": "run",
          "setup": "gcc -std=c17 -Wall -Wextra -Wpedantic -o programa main.c",
          "run": "./programa",
          "timeout": 5,
          "exit-code": 0,
          "points": 2
        },
        {
          "name": "Imprime el saludo",
          "type": "io",
          "setup": "gcc -std=c17 -Wall -Wextra -Wpedantic -o programa main.c",
          "run": "./programa",
          "expected": "Hola Classroom 50",
          "comparison": "included",
          "timeout": 5,
          "points": 4
        }
      ],
      "feedback_pr": true
    }
  ]
